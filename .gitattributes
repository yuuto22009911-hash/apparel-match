# Normalize line endings on commit; check out with native EOL.
* text=auto eol=lf

# Explicit text files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf

# Binary files (no diff, no merge)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.avif      binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.zip       binary

# GitHub linguist hints
*.sql        linguist-detectable=true
package-lock.json linguist-generated=true
